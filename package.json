{
  "name": "wp-ai-image-publisher",
  "productName": "WP AI Image Publisher",
  "version": "0.1.0",
  "description": "Desktop app to analyze WordPress pages, generate SEO images with AI, and publish them to WordPress Media Library.",
  "author": "Yasin",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p electron/tsconfig.json --watch --preserveWatchOutput & node scripts/wait-and-launch.js",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json && node scripts/copy-schema.js",
    "build": "npm run build:renderer && npm run build:electron",
    "package:win": "npm run build && electron-builder --win --x64",
    "package:mac": "npm run build && electron-builder --mac --universal",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "better-sqlite3": "^11.3.0",
    "electron-store": "^8.2.0",
    "keytar": "^7.9.0",
    "sharp": "^0.33.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.yasin.wpaiimagepublisher",
    "productName": "WP AI Image Publisher",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "extraResources": [
      {
        "from": "electron/db/schema.sql",
        "to": "schema.sql"
      }
    ],
    "win": {
     "target": ["nsis"]
   },
   "nsis": {
     "oneClick": false,
     "allowToChangeInstallationDirectory": true
   },
   "mac": {
     "target": ["dmg"],
     "category": "public.app-category.productivity"
   }
